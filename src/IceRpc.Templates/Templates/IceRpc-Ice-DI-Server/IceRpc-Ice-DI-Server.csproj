<?xml version="1.0" encoding="utf-8" ?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Copy the PDBs from the NuGet packages to get file names and line numbers in stack traces. -->
    <CopyDebugSymbolFilesFromPackages>true</CopyDebugSymbolFilesFromPackages>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <SliceCompile>
      <!-- Make the Ice compiler generate code for IceRPC by default. -->
      <IceRpc>true</IceRpc>
    </SliceCompile>
  </ItemDefinitionGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.*" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" Version="10.0.*" />
    <PackageReference Include="ZeroC.Ice.Slice.Tools" Version="[3.8.2,3.9.0)" PrivateAssets="All" />
    <PackageReference Include="IceRpc.Ice" Version="0.6.0" />
    <PackageReference Include="IceRpc.Extensions.DependencyInjection" Version="0.6.0" />
    <PackageReference Include="IceRpc.Logger" Version="0.6.0" />
    <PackageReference Include="IceRpc.Deadline" Version="0.6.0" />
    <!-- The 1.2 beta version is required for supporting the latest language features.
         See: https://github.com/DotNetAnalyzers/StyleCopAnalyzers/pull/3187 -->
    <PackageReference Include="StyleCop.Analyzers" Version="1.2.0-beta.556">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <GlobalAnalyzerConfigFiles Include="$(MSBuildThisFileDirectory)CodeAnalysis.globalconfig" />
  </ItemGroup>
  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="certs\**">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
