<?xml version="1.0" encoding="utf-8" ?>
<!-- Copyright (c) ZeroC, Inc. -->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <EnableDefaultSliceFileItems Condition="'$(EnableDefaultSliceFileItems)' == ''">true</EnableDefaultSliceFileItems>
    <!-- Internal properties used to compute the slicec compiler location for the current platform. -->
    <_IceRpcOSName Condition="$([MSBuild]::IsOSPlatform('Linux'))">linux</_IceRpcOSName>
    <_IceRpcOSName Condition="$([MSBuild]::IsOSPlatform('Windows'))">windows</_IceRpcOSName>
    <_IceRpcOSName Condition="$([MSBuild]::IsOSPlatform('OSX'))">macos</_IceRpcOSName>
    <_IceRpcOSArch>$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture.ToString().ToLower())</_IceRpcOSArch>
    <_SliceGeneratorScriptExtension Condition="$([MSBuild]::IsOSPlatform('Windows'))">.bat</_SliceGeneratorScriptExtension>
    <_SliceGeneratorScriptExtension Condition="!$([MSBuild]::IsOSPlatform('Windows'))">.sh</_SliceGeneratorScriptExtension>
  </PropertyGroup>
  <Choose>
    <When Condition="Exists('$(MSBuildThisFileDirectory)../ZeroC.Slice.Generator')">
      <!--
        Use the slicec compiler from the obj/tools directory and the generator assemblies from source builds.
      -->
      <PropertyGroup>
        <_IceRpcSliceToolsSourceBuild>true</_IceRpcSliceToolsSourceBuild>
        <_SliceCPath>$(MSBuildThisFileDirectory)obj/tools/$(_IceRpcOSName)-$(_IceRpcOSArch)</_SliceCPath>
        <_ZeroCSliceGeneratorPath>$(MSBuildThisFileDirectory)../ZeroC.Slice.Generator/bin/$(Configuration)/net10.0/</_ZeroCSliceGeneratorPath>
        <_IceRpcSliceGeneratorPath>$(MSBuildThisFileDirectory)../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/</_IceRpcSliceGeneratorPath>

        <!-- Use tools assembly built from source -->
        <_IceRpcSliceToolsTaskAssembliesPath>$(MSBuildThisFileDirectory)bin/$(Configuration)/net10.0/</_IceRpcSliceToolsTaskAssembliesPath>

        <!-- Force task to run out of process to avoid issues with files in use -->
        <_IceRpcSliceToolsTaskFactory>TaskHostFactory</_IceRpcSliceToolsTaskFactory>
      </PropertyGroup>
    </When>
    <Otherwise>
      <!-- Use the slicec compiler and generators from this NuGet package -->
      <PropertyGroup>
        <_SliceCPath>$(MSBuildThisFileDirectory)../tools/$(_IceRpcOSName)-$(_IceRpcOSArch)</_SliceCPath>
        <_ZeroCSliceGeneratorPath>$(MSBuildThisFileDirectory)../tools/</_ZeroCSliceGeneratorPath>
        <_IceRpcSliceGeneratorPath>$(MSBuildThisFileDirectory)../tools/</_IceRpcSliceGeneratorPath>
        <_IceRpcSliceToolsTaskAssembliesPath>$(MSBuildThisFileDirectory)../tasks/</_IceRpcSliceToolsTaskAssembliesPath>

         <!-- AssemblyTaskFactory is the default value when no TaskFactory is specified -->
         <_IceRpcSliceToolsTaskFactory>AssemblyTaskFactory</_IceRpcSliceToolsTaskFactory>
      </PropertyGroup>
    </Otherwise>
  </Choose>

  <!-- default values -->
  <ItemDefinitionGroup>
    <SliceFile>
      <OutputDir>$(MSBuildProjectDirectory)/generated</OutputDir>
      <IceRpc>true</IceRpc>
      <Pack>false</Pack>
      <PackagePath>slice</PackagePath>
    </SliceFile>
  </ItemDefinitionGroup>
</Project>
