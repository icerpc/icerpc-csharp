<?xml version="1.0" encoding="utf-8" ?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Copy the PDBs from the NuGet packages to get file names and line numbers in stack traces. -->
    <CopyDebugSymbolFilesFromPackages>true</CopyDebugSymbolFilesFromPackages>
  </PropertyGroup>
  <ItemGroup>
    <SliceFile Include="../slice/ThermoControl.slice;../slice/Reading.slice; ../slice/ThermoHome.slice" />
    <Compile Include="../../../common/Program.Authentication.cs" Link="Program.Authentication.cs" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    <PackageReference Include="IceRpc.Deadline" />
    <PackageReference Include="IceRpc.Logger" />
    <PackageReference Include="IceRpc.Slice.Tools" PrivateAssets="All" />
    <PackageReference Include="IceRpc.Slice" />
    <PackageReference Include="StyleCop.Analyzers">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>
