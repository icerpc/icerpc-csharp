<?xml version="1.0" encoding="utf-8" ?>
<!-- Import this file in projects that need to exclude .IceRpc.cs files generated by slice2cs. These files depend on
     the IceRpc assembly and cannot be compiled in projects that don't reference it. -->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="_IceRpc_ExcludeSliceCompileGenerated" DependsOnTargets="SliceCompile" BeforeTargets="CoreCompile">
    <ItemGroup>
        <Compile Remove="@(Compile)" Condition="$([MSBuild]::ValueOrDefault('%(Filename)', '').EndsWith('.IceRpc'))" />
    </ItemGroup>
  </Target>
</Project>
