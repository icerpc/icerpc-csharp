<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(MSBuildThisFileDirectory)../../build/Extract.targets" />
  <PropertyGroup>
    <AssemblyName>IceRpc.Slice.Tools</AssemblyName>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <TargetFramework>net10.0</TargetFramework>
    <Title>IceRPC Slice Tools</Title>
    <PackageId>$(AssemblyName)</PackageId>
    <Description>Provides tools to generate C# code from Slice definitions; includes support for MSBuild projects.</Description>
    <DevelopmentDependency>true</DevelopmentDependency>
    <PackageTags>IceRPC;RPC;MSBuild;Slice</PackageTags>
    <PackageType>Dependency</PackageType>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IncludeSymbols>false</IncludeSymbols>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <NoWarn>NU5100</NoWarn>
    <!-- Internal properties used to compute the slicec compiler location for the current platform. -->
    <IceRPC_OSName Condition="$([MSBuild]::IsOSPlatform('Linux'))">linux</IceRPC_OSName>
    <IceRPC_OSName Condition="$([MSBuild]::IsOSPlatform('Windows'))">windows</IceRPC_OSName>
    <IceRPC_OSName Condition="$([MSBuild]::IsOSPlatform('OSX'))">macos</IceRPC_OSName>
    <IceRPC_OSArch>$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture.ToString().ToLower())</IceRPC_OSArch>
    <SliceCompilerExe Condition="'$(OS)' == 'Windows_NT'">slicec.exe</SliceCompilerExe>
    <SliceCompilerExe Condition="'$(OS)' != 'Windows_NT'">slicec</SliceCompilerExe>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../ZeroC.Slice.Generator/ZeroC.Slice.Generator.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="../IceRpc.Slice.Generator/IceRpc.Slice.Generator.csproj" ReferenceOutputAssembly="false" />
    <PackageReference Include="Microsoft.Build.Framework" Version="18.0.2" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.0.2" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="../../LICENSE">
      <PackagePath />
      <Pack>true</Pack>
    </Content>
    <Content Include="README.md">
      <PackagePath />
      <Pack>true</Pack>
    </Content>
    <Content Include="IceRpc.Slice.Tools.props">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <Content Include="IceRpc.Slice.Tools.targets">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <Content Include="SliceFile.ProjectProperties.xaml">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <Content Include="SliceFile.FileProperties.xaml">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <Content Include="SliceFile.ItemDefinition.xaml">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <None Include="../../build/icerpc-icon.png">
      <Pack>true</Pack>
      <PackagePath>/</PackagePath>
    </None>
    <None Include="$(OutputPath)/$(AssemblyName).dll" Pack="true" PackagePath="tasks/" Visible="false" />
    <!-- Include the ZeroC.Slice.Generator outputs from source builds. -->
    <None
      Include="../ZeroC.Slice.Generator/bin/$(Configuration)/net10.0/*.dll;
               ../ZeroC.Slice.Generator/bin/$(Configuration)/net10.0/*.pdb"
      Visible="false">
      <PackagePath>tools/</PackagePath>
      <Pack>true</Pack>
    </None>
    <!-- Include the IceRpc.Slice.Generator outputs from source builds, but
         exclude shared dependencies already included by ZeroC.Slice.Generator above. -->
    <None
      Include="../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/*.dll;
               ../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/*.pdb"
      Exclude="../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/Dunet.dll;
               ../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/ZeroC.Slice.Codec.*;
               ../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/ZeroC.Slice.Symbols.*"
      Visible="false">
      <PackagePath>tools/</PackagePath>
      <Pack>true</Pack>
    </None>
  </ItemGroup>
  <Target Name="DownloadSlicec" BeforeTargets="CoreCompile">
    <ItemGroup>
      <SlicecPlatform Include="aarch64-apple-darwin" Prefix="macos-arm64" Exe="slicec" />
      <SlicecPlatform Include="x86_64-unknown-linux-gnu" Prefix="linux-x64" Exe="slicec" />
      <SlicecPlatform Include="aarch64-unknown-linux-gnu" Prefix="linux-arm64" Exe="slicec" />
      <SlicecPlatform Include="x86_64-pc-windows-msvc" Prefix="windows-x64" Exe="slicec.exe" />
    </ItemGroup>

    <!-- Download and extract slicec binaries for all platforms. Each zip is cached in obj/. -->
    <DownloadFile
      SourceUrl="$(SlicecBaseUrl)/slicec-$(SlicecMMVersion)-%(SlicecPlatform.Identity).zip"
      DestinationFolder="$(MSBuildThisFileDirectory)obj"
      Condition="!Exists('$(MSBuildThisFileDirectory)obj/slicec-$(SlicecMMVersion)-%(SlicecPlatform.Identity).zip')" />

    <!-- We use our custom ExtractTask instead of MSBuild Unzip to preserve Unix executable permissions. -->
    <ExtractTask
      SourceFiles="$(MSBuildThisFileDirectory)obj/slicec-$(SlicecMMVersion)-%(SlicecPlatform.Identity).zip"
      DestinationFolder="$(MSBuildThisFileDirectory)obj/slicec-$(SlicecMMVersion)-%(SlicecPlatform.Identity)"
      Condition="!Exists('$(MSBuildThisFileDirectory)obj/slicec-$(SlicecMMVersion)-%(SlicecPlatform.Identity)')" />

    <!-- Copy binaries to the tools directory structure expected by the props file. -->
    <Copy
      SourceFiles="$(MSBuildThisFileDirectory)obj/slicec-$(SlicecMMVersion)-%(SlicecPlatform.Identity)/%(SlicecPlatform.Exe)"
      DestinationFolder="$(MSBuildThisFileDirectory)obj/tools/%(SlicecPlatform.Prefix)"
      SkipUnchangedFiles="true" />

    <!-- Include downloaded slicec binaries in the NuGet package. -->
    <ItemGroup>
      <Content Include="$(MSBuildThisFileDirectory)obj/tools/**" Visible="false">
        <PackagePath>tools/</PackagePath>
        <Pack>true</Pack>
      </Content>
    </ItemGroup>
  </Target>
</Project>
