<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../ZeroC.Slice.Codec/ZeroC.Slice.Codec.csproj" />
  </ItemGroup>

  <!--
    The C# files under Compiler/ are generated by slicec + ZeroC.Slice.Generator from slice/Compiler/*.slice
    and checked in to break a bootstrap cycle (ZeroC.Slice.Generator depends on this assembly). The Regenerate
    target below rewrites them in place using the locally built generator.

    Usage:
      dotnet build
      dotnet build src/ZeroC.Slice.Symbols/ZeroC.Slice.Symbols.csproj -t:Regenerate

    The target deliberately does no build-order plumbing: it assumes a prior `dotnet build` has produced the
    slicec compiler under src/IceRpc.Slice.Tools/obj/tools/<rid>/ and the ZeroC.Slice.Generator + IceRpc.Slice.Tools
    assemblies under their respective bin/$(Configuration)/net10.0/ directories.
  -->
  <UsingTask
    TaskName="IceRpc.Slice.Tools.SlicecTask"
    AssemblyFile="$(MSBuildThisFileDirectory)../IceRpc.Slice.Tools/bin/$(Configuration)/net10.0/IceRpc.Slice.Tools.dll" />

  <Target Name="Regenerate">
    <PropertyGroup>
      <_IceRpcOSName Condition="$([MSBuild]::IsOSPlatform('Linux'))">linux</_IceRpcOSName>
      <_IceRpcOSName Condition="$([MSBuild]::IsOSPlatform('Windows'))">windows</_IceRpcOSName>
      <_IceRpcOSName Condition="$([MSBuild]::IsOSPlatform('OSX'))">macos</_IceRpcOSName>
      <_IceRpcOSArch>$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture.ToString().ToLower())</_IceRpcOSArch>
      <_SliceGeneratorScriptExtension Condition="$([MSBuild]::IsOSPlatform('Windows'))">.bat</_SliceGeneratorScriptExtension>
      <_SliceGeneratorScriptExtension Condition="!$([MSBuild]::IsOSPlatform('Windows'))">.sh</_SliceGeneratorScriptExtension>

      <_SliceCPath>$(MSBuildThisFileDirectory)../IceRpc.Slice.Tools/obj/tools/$(_IceRpcOSName)-$(_IceRpcOSArch)</_SliceCPath>
      <_SliceGenerators>$(MSBuildThisFileDirectory)../ZeroC.Slice.Generator/bin/$(Configuration)/net10.0/slicec-csharp-generator$(_SliceGeneratorScriptExtension)</_SliceGenerators>

      <_RegenerateOutputDir>$(MSBuildThisFileDirectory)Compiler</_RegenerateOutputDir>
      <_RegenerateSliceDir>$(MSBuildThisFileDirectory)../../slice/Compiler</_RegenerateSliceDir>
    </PropertyGroup>

    <ItemGroup>
      <_RegenerateSliceFile Include="$(_RegenerateSliceDir)/*.slice" />
    </ItemGroup>

    <SlicecTask
      WorkingDirectory="$(MSBuildProjectDirectory)"
      OutputDir="$(_RegenerateOutputDir)"
      ToolsPath="$(_SliceCPath)"
      Generators="$(_SliceGenerators)"
      Sources="@(_RegenerateSliceFile)" />
  </Target>
</Project>
