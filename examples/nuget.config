<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Define the package sources, nuget.org, and icerpc.dev. -->
  <!-- `clear` ensures no additional sources are inherited from another config file. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="icerpc.dev" value="https://download.zeroc.com/nexus/repository/nuget-nightly/" />
  </packageSources>

  <!-- Define mappings by adding package patterns beneath the target source. -->
  <!-- zeroc.slice.codec and icerpc.* packages will be restored from icerpc.dev, everything else from nuget.org. -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="icerpc.dev">
      <package pattern="icerpc.*" />
      <package pattern="icerpc" />
      <package pattern="zeroc.slice" />
      <package pattern="zeroc.slice.codec" />
    </packageSource>
  </packageSourceMapping>
</configuration>
