<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>IceRpc.Slice.Tools</AssemblyName>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <TargetFramework>net10.0</TargetFramework>
    <Title>IceRPC Slice Tools</Title>
    <PackageId>$(AssemblyName)</PackageId>
    <Description>Provides tools to generate C# code from Slice definitions; includes support for MSBuild projects.</Description>
    <DevelopmentDependency>true</DevelopmentDependency>
    <PackageTags>IceRPC;RPC;MSBuild;Slice</PackageTags>
    <PackageType>Dependency</PackageType>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IncludeSymbols>false</IncludeSymbols>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <NoWarn>NU5100</NoWarn>
    <!-- Internal properties used to compute the slicec compiler location for the current platform. -->
    <IceRPC_OSName Condition="$([MSBuild]::IsOSPlatform('Linux'))">linux</IceRPC_OSName>
    <IceRPC_OSName Condition="$([MSBuild]::IsOSPlatform('Windows'))">windows</IceRPC_OSName>
    <IceRPC_OSName Condition="$([MSBuild]::IsOSPlatform('OSX'))">macos</IceRPC_OSName>
    <IceRPC_OSArch>$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture.ToString().ToLower())</IceRPC_OSArch>
    <SliceCompilerExe Condition="'$(OS)' == 'Windows_NT'">slicec.exe</SliceCompilerExe>
    <SliceCompilerExe Condition="'$(OS)' != 'Windows_NT'">slicec</SliceCompilerExe>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../ZeroC.Slice.Generator/ZeroC.Slice.Generator.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="../IceRpc.Slice.Generator/IceRpc.Slice.Generator.csproj" ReferenceOutputAssembly="false" />
    <PackageReference Include="Microsoft.Build.Framework" Version="18.0.2" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="18.0.2" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="../../LICENSE">
      <PackagePath />
      <Pack>true</Pack>
    </Content>
    <Content Include="README.md">
      <PackagePath />
      <Pack>true</Pack>
    </Content>
    <Content Include="IceRpc.Slice.Tools.props">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <Content Include="IceRpc.Slice.Tools.targets">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <Content Include="SliceFile.ProjectProperties.xaml">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <Content Include="SliceFile.FileProperties.xaml">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <Content Include="SliceFile.ItemDefinition.xaml">
      <PackagePath>build/</PackagePath>
      <Pack>true</Pack>
    </Content>
    <None Include="../../build/icerpc-icon.png">
      <Pack>true</Pack>
      <PackagePath>/</PackagePath>
    </None>
    <None Include="$(OutputPath)/$(AssemblyName).dll" Pack="true" PackagePath="tasks/" Visible="false" />
    <!-- Include the generator outputs from source builds. -->
    <None
      Include="../ZeroC.Slice.Generator/bin/$(Configuration)/net10.0/*"
      Visible="false">
      <PackagePath>tools/</PackagePath>
      <Pack>true</Pack>
    </None>
    <!-- Exclude shared dependencies already included by ZeroC.Slice.Generator above. -->
    <None
      Include="../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/*"
      Exclude="../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/Dunet.dll;
               ../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/ZeroC.Slice.Codec.*;
               ../IceRpc.Slice.Generator/bin/$(Configuration)/net10.0/ZeroC.Slice.Symbols.*"
      Visible="false">
      <PackagePath>tools/</PackagePath>
      <Pack>true</Pack>
    </None>
  </ItemGroup>
  <Choose>
    <When Condition="Exists('$(SLICEC_STAGING_PATH)')">
      <!-- Use the pre-built compilers from SLICEC_STAGING_PATH. -->
      <ItemGroup>
        <Content Include="$(SLICEC_STAGING_PATH)/linux-x64/slicec">
          <PackagePath>tools/linux-x64/</PackagePath>
          <Pack>true</Pack>
        </Content>
        <Content Include="$(SLICEC_STAGING_PATH)/linux-arm64/slicec">
          <PackagePath>tools/linux-arm64/</PackagePath>
          <Pack>true</Pack>
        </Content>
        <Content Include="$(SLICEC_STAGING_PATH)/macos-arm64/slicec">
          <PackagePath>tools/macos-arm64/</PackagePath>
          <Pack>true</Pack>
        </Content>
        <Content Include="$(SLICEC_STAGING_PATH)/windows-x64/slicec.exe">
          <PackagePath>tools/windows-x64/</PackagePath>
          <Pack>true</Pack>
        </Content>
      </ItemGroup>
    </When>
  </Choose>
</Project>
